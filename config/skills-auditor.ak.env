# Source with: set -a && source /path/to/AK.skill/config/skills-auditor.ak.env && set +a
# Adjust AK_SKILL_ROOT if the repo is not at ~/AK.skill

AK_SKILL_ROOT="${AK_SKILL_ROOT:-$HOME/AK.skill}"
export SKILLS_AUDITOR_EXTRA_ROOTS="$AK_SKILL_ROOT/skills"
export SKILLS_AUDITOR_WITH_DRIFT="${SKILLS_AUDITOR_WITH_DRIFT:-1}"
export SKILLS_AUDITOR_ROUTE_PLATFORMS="${SKILLS_AUDITOR_ROUTE_PLATFORMS:-cursor,codex}"
export SKILLS_AUDITOR_ROUTE_STRATEGY="${SKILLS_AUDITOR_ROUTE_STRATEGY:-archive}"
